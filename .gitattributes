# Auto detect text files and perform LF normalization
* text=auto

# Launchers must keep their native line endings no matter which OS the repo is
# checked out on: a CRLF run.sh breaks /bin/sh ("bad interpreter"), and an
# LF-only run.bat can confuse old cmd.exe parsers. tools/release.py normalises
# both again when packaging, but the checkout should already be correct.
run.sh  text eol=lf
run.bat text eol=crlf
